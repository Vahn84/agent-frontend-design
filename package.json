{
  "name": "agent-frontend-design",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Figma REST-only frontend agent. No MCP.",
  "bin": {
    "afd": "bin/cli.mjs"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "smoke": "node bin/cli.mjs",
    "validate-contract": "node scripts/prepare-build.mjs --validate",
    "slice": "node scripts/prepare-build.mjs --slice",
    "validate": "node scripts/validate.mjs",
    "screenshot": "node scripts/screenshot.mjs",
    "normalize-icons": "node scripts/normalize-icons.mjs",
    "verify-glyphs": "node scripts/verify-glyphs.mjs",
    "check-wrappers": "node scripts/check-wrappers.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.48.0",
    "pngjs": "^7.0.0"
  },
  "engines": {
    "node": ">=18.17"
  }
}
