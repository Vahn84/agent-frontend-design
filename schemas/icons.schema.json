{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Icons",
  "description": "Icon inventory. Source = library file (R2), not mockup instances.",
  "type": "object",
  "required": ["source", "strategy", "icons"],
  "properties": {
    "source": {
      "type": "object",
      "required": ["fileKey"],
      "properties": {
        "fileKey": { "type": "string" },
        "pageId": { "type": "string" }
      }
    },
    "strategy": { "enum": ["webfont", "svg"] },
    "webfont": {
      "type": "object",
      "properties": {
        "prefix": { "type": "string" },
        "fontName": { "type": "string" },
        "viewBox": { "type": "string", "description": "e.g. '0 0 32 32'" },
        "glyphInnerScale": {
          "type": "number",
          "description": "Fraction of viewBox occupied by glyph (e.g. 0.5 → visible*2 sizing rule R12)"
        }
      }
    },
    "icons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "nodeId", "vectorNodeId"],
        "properties": {
          "name": { "type": "string" },
          "nodeId": {
            "type": "string",
            "description": "Icon component node in library."
          },
          "vectorNodeId": {
            "type": "string",
            "description": "Inner vector child node — this is what gets exported (R2)."
          },
          "componentKey": { "type": "string" },
          "viewBox": { "type": "string" },
          "defaultVisibleSizePx": {
            "type": "number",
            "description": "Most common visible size on mockups. Build uses this when no override."
          },
          "svgPath": { "type": "string", "description": "Relative export path if strategy=svg." },
          "glyphCode": { "type": "string", "description": "Webfont codepoint if strategy=webfont." }
        }
      }
    }
  }
}
