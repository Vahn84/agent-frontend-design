{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Typography",
  "description": "Text style lookup. Keys = style name from Figma. Values = fully resolved CSS properties.",
  "type": "object",
  "required": ["styles"],
  "properties": {
    "styles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["fontFamily", "fontSize", "fontWeight", "lineHeight"],
        "properties": {
          "fontFamily": { "type": "string" },
          "fontSize": { "type": "string", "description": "with unit (e.g. 14px, 0.875rem)" },
          "fontWeight": { "type": "number" },
          "lineHeight": { "type": "string", "description": "with unit or unitless" },
          "letterSpacing": { "type": "string", "description": "with unit" },
          "textTransform": { "enum": ["none", "uppercase", "lowercase", "capitalize"] },
          "textDecoration": { "type": "string" },
          "cssVar": {
            "type": ["string", "null"],
            "description": "Optional composite CSS var if style is itself a token."
          }
        }
      }
    }
  }
}
